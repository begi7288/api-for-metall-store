# Database connection string. For Docker use host `db`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/metal_store"
JWT_SECRET="replace_this_with_a_secure_random_secret"
JWT_EXPIRES_IN="1h"
FRONTEND_URL="https://genuine-sunburst-2b0906.netlify.app/"
CORS_ALLOW_CREDENTIALS=false
PORT=3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
NODE_ENV=development

# Use a long, random value for JWT_SECRET in production (minimum 32 characters).
# Copy this file to .env in production and keep secrets out of source control.

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

